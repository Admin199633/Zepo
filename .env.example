# Zepo Poker — Environment Variables
# Copy to .env and fill in production values.
# All variables have safe defaults for local development.

# ---------------------------------------------------------------------------
# App
# ---------------------------------------------------------------------------
APP_ENV=development         # set to "production" in prod
DEBUG=false                 # set true for verbose FastAPI errors

# ---------------------------------------------------------------------------
# Database (used by SqlitePersistenceAdapter — not active in dev)
# ---------------------------------------------------------------------------
DATABASE_URL=sqlite+aiosqlite:///./poker.db
# Production: postgres+asyncpg://user:password@host:5432/zepo

# ---------------------------------------------------------------------------
# Cache / Redis (not active in dev — in-process broadcaster used)
# ---------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0
USE_REDIS=false             # set true to enable Redis broadcaster

# ---------------------------------------------------------------------------
# Auth — JWT
# ---------------------------------------------------------------------------
JWT_SECRET=CHANGE_ME_IN_PRODUCTION   # ← MUST be changed before going live
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=24

# ---------------------------------------------------------------------------
# SMS (dev uses ConsoleAuthService — OTP printed to stdout)
# ---------------------------------------------------------------------------
SMS_PROVIDER=console        # "console" (dev) | "twilio" (prod)
SMS_FROM_NUMBER=            # Twilio from-number (prod only)
TWILIO_ACCOUNT_SID=         # Twilio account SID (prod only)
TWILIO_AUTH_TOKEN=          # Twilio auth token (prod only)

# ---------------------------------------------------------------------------
# Game
# ---------------------------------------------------------------------------
DISCONNECT_TIMEOUT_SECONDS=60   # seconds to hold a seat after WS drop
BETWEEN_HANDS_DELAY_SECONDS=3.0 # pause between hands so players see result
REQUEST_ID_TTL_SECONDS=60       # idempotency window for duplicate request_id
EXPO_PUBLIC_API_URL=http://10.100.102.3:8000
EXPO_PUBLIC_WS_URL=ws://10.100.102.3:8000